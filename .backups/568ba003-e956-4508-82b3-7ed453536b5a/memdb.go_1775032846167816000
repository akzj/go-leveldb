package memdb

import (
	"github.com/akzj/go-leveldb/util"
)

// Iterator interface for memdb operations.
// Why not extend db.Iterator? memdb is a low-level package that shouldn't
// depend on db package to avoid import cycles.
type Iterator interface {
	Valid() bool
	SeekToFirst()
	SeekToLast()
	Seek(target util.Slice)
	Next()
	Prev()
	Key() util.Slice
	Value() util.Slice
	Status() *util.Status
	// Release releases the iterator resources.
	// No-op for memdb since skiplist iterator doesn't hold external resources.
	Release()
}

// MemDB is an in-memory skip-list based storage for memtable.
type MemDB struct {
	comparator util.Comparator
	skiplist   *SkipList
	arena      *util.Arena
}

// NewMemDB creates a new memtable with the given comparator.
func NewMemDB(comparator util.Comparator) *MemDB {
	arena := util.NewArena()
	return &MemDB{
		comparator: comparator,
		skiplist:   NewSkipList(comparator, arena),
		arena:      arena,
	}
}

// Put stores a key-value pair in the memtable.
func (m *MemDB) Put(key, value util.Slice) *util.Status {
	m.skiplist.Insert(key.Data(), value.Data())
	return util.NewStatusOK()
}

// Get looks up a key in the memtable.
// Returns (nil, NotFound) if key doesn't exist or is a deletion marker.
func (m *MemDB) Get(key util.Slice) ([]byte, *util.Status) {
	node := m.skiplist.Find(key.Data())
	if node == nil {
		return nil, util.NotFound("")
	}
	// Check if this is a deletion marker (type byte at end is 0 for deletion)
	if isDeletionMarker(key.Data()) {
		return nil, util.NotFound("")
	}
	return node.value, util.NewStatusOK()
}

// FindForSnapshot finds an entry for the given user key that is visible
// at the given snapshot sequence number.
// Returns (value, nil, ok) if found and not deleted.
// Returns (nil, nil, ok) if found but deleted.
// Returns (nil, NotFound, false) if not found.
func (m *MemDB) FindForSnapshot(userKey util.Slice, snapshotSeq uint64) ([]byte, *util.Status, bool) {
	// Create a seek key with snapshotSeq and KTypeValue (1)
	// This positions us at or near entries for this user key
	seekKey := append([]byte{}, userKey.Data()...)
	// Append sequence (7 bytes big-endian) and type (1 byte = 1 for KTypeValue)
	seekKey = append(seekKey,
		byte(snapshotSeq>>48),
		byte(snapshotSeq>>40),
		byte(snapshotSeq>>32),
		byte(snapshotSeq>>24),
		byte(snapshotSeq>>16),
		byte(snapshotSeq>>8),
		byte(snapshotSeq),
		byte(1), // KTypeValue
	)

	iter := m.skiplist.NewIterator()
	iter.Seek(util.MakeSlice(seekKey))

	// Track the best (highest sequence) non-deleted entry we find
	var bestKey []byte
	var bestValue []byte
	var bestIsDeletion bool

	// Search backward from seek position to find all entries for this user key
	for iter.Valid() {
		keyBytes := iter.Key().Data()
		if len(keyBytes) < 8 {
			break
		}
		// Extract user key from this entry
		userKeyLen := len(keyBytes) - 8
		if string(keyBytes[:userKeyLen]) != string(userKey.Data()) {
			// Different user key, we've gone too far back
			break
		}
		// Extract sequence number (7 bytes, big-endian)
		var seq uint64
		for i := 0; i < 7; i++ {
			seq = (seq << 8) | uint64(keyBytes[userKeyLen+i])
		}
		// Check if this entry is visible at our snapshot
		if seq <= snapshotSeq {
			isDeletion := keyBytes[len(keyBytes)-1] == 0 // KTypeDeletion = 0
			// Update best if this entry has a higher sequence
			if bestKey == nil || seq > bestSeq(bestKey) {
				bestKey = keyBytes
				bestValue = iter.Value().Data()
				bestIsDeletion = isDeletion
			}
		}
		iter.Prev()
	}

	// If no entry found backward, search forward too
	if bestKey == nil {
		iter.Seek(util.MakeSlice(seekKey))
		iter.Next()
		for iter.Valid() {
			keyBytes := iter.Key().Data()
			if len(keyBytes) < 8 {
				break
			}
			userKeyLen := len(keyBytes) - 8
			if string(keyBytes[:userKeyLen]) != string(userKey.Data()) {
				break
			}
			var seq uint64
			for i := 0; i < 7; i++ {
				seq = (seq << 8) | uint64(keyBytes[userKeyLen+i])
			}
			if seq <= snapshotSeq {
				isDeletion := keyBytes[len(keyBytes)-1] == 0
				if bestKey == nil || seq > bestSeq(bestKey) {
					bestKey = keyBytes
					bestValue = iter.Value().Data()
					bestIsDeletion = isDeletion
				}
			}
			iter.Next()
		}
	}

	if bestKey == nil {
		return nil, util.NotFound(""), false
	}
	if bestIsDeletion {
		return nil, nil, true // Found but deleted
	}
	return bestValue, util.NewStatusOK(), true
}

// bestSeq extracts the sequence number from a key for comparison
func bestSeq(keyBytes []byte) uint64 {
	if len(keyBytes) < 8 {
		return 0
	}
	var seq uint64
	userKeyLen := len(keyBytes) - 8
	for i := 0; i < 7; i++ {
		seq = (seq << 8) | uint64(keyBytes[userKeyLen+i])
	}
	return seq
}

// isDeletionMarker checks if the internal key represents a deletion.
// Internal key format: [user_key][7 bytes sequence][1 byte type]
// Type 0x0 = KTypeDeletion, 0x1 = KTypeValue
func isDeletionMarker(encodedKey []byte) bool {
	if len(encodedKey) < 8 {
		return false
	}
	return encodedKey[len(encodedKey)-1] == 0 // KTypeDeletion = 0
}

// Delete removes a key from the memtable.
// In LevelDB, deletion is done by inserting a tombstone marker.
func (m *MemDB) Delete(key util.Slice) *util.Status {
	// LevelDB marks deletion with a special value
	// We use nil value with deletion semantics
	// The skiplist Insert will update existing key with new value
	m.skiplist.Insert(key.Data(), []byte{})
	return util.NewStatusOK()
}

// NewIterator returns an iterator over the memtable.
func (m *MemDB) NewIterator() Iterator {
	return m.skiplist.NewIterator()
}

// ApproximateMemoryUsage returns the approximate memory usage of the memtable.
func (m *MemDB) ApproximateMemoryUsage() int {
	return m.skiplist.ApproximateMemoryUsage()
}
