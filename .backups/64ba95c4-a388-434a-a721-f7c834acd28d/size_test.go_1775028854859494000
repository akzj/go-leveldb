package db

import (
	"testing"

	"github.com/akzj/go-leveldb/util"
)

// TestGetApproximateSizes tests that GetApproximateSizes returns non-zero
// sizes after writing data.
// Invariant: After writing data, approximate sizes should be > 0.
func TestGetApproximateSizes(t *testing.T) {
	db := newTestDB(t)

	// Write some data
	for i := 0; i < 10; i++ {
		key := util.MakeSlice([]byte("key"))
		key.Append([]byte(byte('0' + i)))
		val := util.MakeSlice([]byte("value"))
		val.Append([]byte(byte('0' + i)))
		db.Put(nil, key, val)
	}

	// Get approximate size for the entire database
	ranges := []Range{
		{Start: []byte("key00"), Limit: []byte("key99")},
	}
	sizes := db.GetApproximateSizes(ranges)

	if len(sizes) != 1 {
		t.Fatalf("Expected 1 size, got %d", len(sizes))
	}

	if sizes[0] == 0 {
		t.Errorf("Expected non-zero approximate size after writing data, got 0")
	}

	// Size should be at least large enough for our data
	if sizes[0] < 100 {
		t.Logf("Approximate size is %d (may be small for new database)", sizes[0])
	}
}

// TestGetApproximateSizesEmpty tests that GetApproximateSizes returns 0
// or near-0 for empty database.
// Invariant: Empty database should have minimal or zero size.
func TestGetApproximateSizesEmpty(t *testing.T) {
	db := newTestDB(t)

	// Get approximate size for entire key range
	ranges := []Range{
		{Start: []byte(""), Limit: []byte("\xff")}, // All possible keys
	}
	sizes := db.GetApproximateSizes(ranges)

	if len(sizes) != 1 {
		t.Fatalf("Expected 1 size, got %d", len(sizes))
	}

	// Empty DB should have minimal size (likely 0 or very small)
	if sizes[0] > 1000 {
		t.Errorf("Expected small approximate size for empty DB, got %d", sizes[0])
	}
}

// TestGetApproximateSizesMultipleRanges tests GetApproximateSizes with multiple ranges.
func TestGetApproximateSizesMultipleRanges(t *testing.T) {
	db := newTestDB(t)

	// Write data in two distinct ranges
	// First range: key000-key099
	for i := 0; i < 10; i++ {
		key := util.MakeSlice([]byte("key"))
		key.Append([]byte(byte('0' + i)))
		key.Append([]byte("0"))
		key.Append([]byte(byte('0' + i)))
		db.Put(nil, key, util.MakeSlice([]byte("value")))
	}

	// Second range: key900-key999
	for i := 0; i < 10; i++ {
		key := util.MakeSlice([]byte("key9"))
		key.Append([]byte(byte('0' + i)))
		db.Put(nil, key, util.MakeSlice([]byte("value")))
	}

	// Get approximate sizes for both ranges
	ranges := []Range{
		{Start: []byte("key000"), Limit: []byte("key100")},
		{Start: []byte("key900"), Limit: []byte("key999")},
	}
	sizes := db.GetApproximateSizes(ranges)

	if len(sizes) != 2 {
		t.Fatalf("Expected 2 sizes, got %d", len(sizes))
	}

	// Both ranges should have some data
	if sizes[0] == 0 {
		t.Logf("First range size is 0 (may be normal for freshly written data)")
	}
	if sizes[1] == 0 {
		t.Logf("Second range size is 0 (may be normal for freshly written data)")
	}
}
