package db

import (
	"github.com/akzj/go-leveldb/util"
)

// FilterPolicy is an interface for creating and checking filters.
// Filters are used to reduce disk reads during DB::Get() calls.
type FilterPolicy interface {
	// Name returns the name of the filter policy.
	// If the filter encoding changes incompatibly, the name must change.
	Name() string

	// CreateFilter creates a filter from a set of keys.
	// Appends the filter to dst.
	// Does not modify the initial contents of dst.
	CreateFilter(keys []util.Slice, dst []byte) []byte

	// KeyMayMatch returns true if the key may be in the filter.
	// May return true or false if the key is not in the filter,
	// but should return false with high probability.
	KeyMayMatch(key, filter util.Slice) bool
}

// BloomFilterPolicy implements a bloom filter.
// Invariant: k_ = bitsPerKey * 0.69, clamped to [1, 30]
// Invariant: filter[len-1] stores k_ (number of hash probes)
// Invariant: bits = (len(filter) - 1) * 8
// Format matches C++ leveldb.BuiltinBloomFilter2 exactly.
type BloomFilterPolicy struct {
	bitsPerKey int
	k          int // number of probes = bitsPerKey * 0.69, clamped to [1, 30]
}

// NewBloomFilterPolicy creates a new bloom filter policy.
// A good value for bitsPerKey is 10, which yields ~1% false positive rate.
// Why not just bitsPerKey? k_ is precomputed to avoid floating point in hot path.
func NewBloomFilterPolicy(bitsPerKey int) *BloomFilterPolicy {
	k := int(float64(bitsPerKey) * 0.69) // ln(2) ≈ 0.69
	if k < 1 {
		k = 1
	}
	if k > 30 {
		k = 30
	}
	return &BloomFilterPolicy{bitsPerKey: bitsPerKey, k: k}
}

// Name implements FilterPolicy.
func (p *BloomFilterPolicy) Name() string {
	return "leveldb.BuiltinBloomFilter2"
}

// bloomHash computes the hash value for a key.
// Uses MurmurHash-inspired algorithm matching C++ BloomHash in util/bloom.cc.
// Why not just Hash()? BloomHash uses fixed seed 0xbc9f1d34, not caller-provided.
func bloomHash(key util.Slice) uint32 {
	return util.Hash(key.Data(), 0xbc9f1d34)
}

// CreateFilter implements FilterPolicy.
// Uses double-hashing technique from [Kirsch, Mitzenmacher 2006].
// h_i = h + i * ((h >> 17) | (h << 15))
// Format: [filter bits][k byte] where k = number of probes
func (p *BloomFilterPolicy) CreateFilter(keys []util.Slice, dst []byte) []byte {
	// Compute bloom filter size
	n := len(keys)
	if n == 0 {
		return append(dst, byte(p.k)) // Still store k
	}

	bits := n * p.bitsPerKey
	if bits < 64 {
		bits = 64
	}
	bytes := (bits + 7) / 8
	bits = bytes * 8

	// Append k bytes of zeros, then k
	initSize := len(dst)
	dst = append(dst, make([]byte, bytes+1)...)
	dst[initSize+bytes] = byte(p.k)
	array := dst[initSize : initSize+bytes]

	for _, key := range keys {
		h := bloomHash(key)
		// Double hashing: delta = (h >> 17) | (h << 15)
		delta := (h >> 17) | (h << 15)
		for i := 0; i < p.k; i++ {
			bitpos := h % bits
			array[bitpos/8] |= (1 << (bitpos % 8))
			h += delta
		}
	}

	return dst
}

// KeyMayMatch implements FilterPolicy.
// Returns false if key is definitely not in filter (no false negatives).
// Returns true with ~1% probability if key is not in filter (false positives OK).
// Why check k > 30? Reserved for future encodings that use shorter filters.
func (p *BloomFilterPolicy) KeyMayMatch(key, filter util.Slice) bool {
	filterData := filter.Data()
	filterLen := len(filterData)

	if filterLen < 2 {
		return false
	}

	// bits = (len - 1) * 8 (last byte is k)
	bits := (filterLen - 1) * 8

	// Get k from filter (last byte)
	k := int(filterData[filterLen-1])
	if k > 30 {
		// Reserved for future encodings - be conservative
		return true
	}

	h := bloomHash(key)
	// Double hashing delta
	delta := (h >> 17) | (h << 15)

	for i := 0; i < k; i++ {
		bitpos := h % bits
		if (filterData[bitpos/8] & (1 << (bitpos % 8))) == 0 {
			return false
		}
		h += delta
	}

	return true
}
